{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mist83/.claude/hooks/doctrine-write-fence.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mist83/.claude/hooks/mullmania-s3-resync.sh",
            "if": "Bash(aws s3 *)",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ]
  }
}
