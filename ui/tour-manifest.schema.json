{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ui.mullmania.com/tour-manifest.schema.json",
  "title": "ui.mullmania.com Tour Manifest",
  "type": "object",
  "required": ["version", "title", "traversal", "viewport", "nodes"],
  "properties": {
    "version": { "const": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "traversal": { "enum": ["ordered", "breadth-first", "depth-first", "importance"] },
    "narrationFallback": { "enum": ["description", "none"] },
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number", "minimum": 320 },
        "height": { "type": "number", "minimum": 240 }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "label", "description", "route", "durationMs", "actions"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["tab", "item"] },
          "parentId": { "type": ["string", "null"] },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "route": { "type": "string", "minLength": 1 },
          "order": { "type": "number" },
          "importance": { "type": "number" },
          "durationMs": { "type": "number", "minimum": 250 },
          "theme": { "type": "string" },
          "mode": { "type": "string" },
          "narration": { "type": "string" },
          "anchors": { "type": "array" },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "enum": ["visit", "focus", "activate", "scroll", "zoom", "pause", "snapshot", "callout"]
                },
                "target": { "type": "string" },
                "value": {},
                "durationMs": { "type": "number" }
              }
            }
          }
        }
      }
    }
  }
}
